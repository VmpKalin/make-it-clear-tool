{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TextPilot",
  "version": "0.1.0",
  "identifier": "dev.textpilot.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @textpilot/desktop dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --filter @textpilot/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "TextPilot",
        "width": 420,
        "height": 300,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
